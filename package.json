{
  "name": "toloverunner-v2",
  "version": "2.4.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "dev:fast": "vite --host --open",
    "install:pnpm": "pnpm install --frozen-lockfile --prefer-offline",
    "install:yarn": "yarn install --frozen-lockfile --prefer-offline",
    "install:bun": "bun install",
    "start:pnpm": "pnpm install --frozen-lockfile --prefer-offline && pnpm dev",
    "start:yarn": "yarn install --frozen-lockfile --prefer-offline && yarn dev",
    "start:bun": "bun install && bun dev",
    "clean": "rm -rf node_modules node_modules_old dist .vite",
    "clean:win": "if exist node_modules rmdir /s /q node_modules & if exist node_modules_old rmdir /s /q node_modules_old & if exist dist rmdir /s /q dist & if exist .vite rmdir /s /q .vite & echo Cleaned",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:integration": "vitest run tests/integration",
    "security:audit": "npm audit --audit-level=high",
    "build:prod": "vite build"
  },
  "dependencies": {
    "@dimforge/rapier3d": "^0.19.3",
    "@react-three/drei": "^9.99.0",
    "@react-three/fiber": "^8.15.16",
    "@react-three/postprocessing": "^2.16.0",
    "@react-three/rapier": "^1.2.0",
    "@sentry/browser": "^7.100.0",
    "@sentry/react": "^7.100.0",
    "clsx": "^2.1.1",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.309.0",
    "postprocessing": "^6.34.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.159.0",
    "zustand": "^4.5.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^2.14.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.1.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.159.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.18.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.2.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
