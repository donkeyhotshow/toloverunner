# ToLOVERunner Environment Variables
# Скопируйте в .env и заполните значения. Не коммитьте .env.

# Sentry Configuration (Production Error Monitoring)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id
VITE_SENTRY_ORG=your-org
VITE_SENTRY_PROJECT=toloverunner-v2
VITE_SENTRY_AUTH_TOKEN=your-auth-token

# App Configuration (VITE_APP_VERSION optional — по умолчанию берётся из package.json при сборке)
# VITE_APP_VERSION=2.4.0
VITE_APP_ENVIRONMENT=production

# WebSocket server URL for multiplayer
VITE_WS_URL=ws://localhost:8080

# PeerJS Configuration
VITE_PEER_HOST=0.peerjs.com
VITE_PEER_PORT=443
VITE_PEER_PATH=/
VITE_PEER_KEY=peerjs
VITE_PEER_SECURE=true

# Performance Monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_DEBUG_OVERLAY=false

# Feature Flags
VITE_ENABLE_MULTIPLAYER=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=true

# Firebase (optional — только если используете Firebase в приложении)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_DATABASE_URL=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=